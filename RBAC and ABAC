New-ADGroup -Name "ROLE_Nurse"      -GroupScope Global -GroupCategory Security -Path $ou
New-ADGroup -Name "ROLE_Physician"  -GroupScope Global -GroupCategory Security -Path $ou
New-ADGroup -Name "ROLE_ITAdmin"    -GroupScope Global -GroupCategory Security -Path $ou
New-ADGroup -Name "ROLE_Auditor"    -GroupScope Global -GroupCategory Security -Path $ou

