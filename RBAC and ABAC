### 1.3 RBAC with Python Simulation

Save this as `rbac_sim.py`:

```python
#!/usr/bin/env python3
"""
RBAC Simulation — Healthcare Example
"""

# --- Define permissions ---
PERMISSIONS = {
    "read_patient_records",
    "update_patient_records",
    "prescribe_medication",
    "view_audit_logs",
    "manage_users",
    "view_billing"
}

# --- Define roles and their permissions ---
ROLES = {
    "Nurse": {
        "read_patient_records",
        "view_billing"
    },
    "Physician": {
        "read_patient_records",
        "update_patient_records",
        "prescribe_medication",
        "view_billing"
    },
    "ITAdmin": {
        "manage_users",
        "view_audit_logs"
    },
    "Auditor": {
        "view_audit_logs",
        "view_billing"
    }
}

# --- Assign users to roles ---
USERS = {
    "alice.johnson": {"role": "Nurse"},
    "bob.smith":     {"role": "Physician"},
    "carol.davis":   {"role": "ITAdmin"},
    "dan.lee":       {"role": "Auditor"}
}


def check_access(username: str, permission: str) -> bool:
    """Evaluate whether a user has a given permission via their role."""
    user = USERS.get(username)
    if not user:
        print(f"  ❌ DENIED  — User '{username}' not found")
        return False

    role = user["role"]
    allowed = ROLES.get(role, set())

    if permission in allowed:
        print(f"  ✅ GRANTED — {username} ({role}) → {permission}")
        return True
    else:
        print(f"  ❌ DENIED  — {username} ({role}) does not have '{permission}'")
        return False


def print_role_matrix():
    """Print a permission matrix for all roles."""
    from tabulate import tabulate

    perms = sorted(PERMISSIONS)
    headers = ["Permission"] + list(ROLES.keys())
    rows = []

    for perm in perms:
        row = [perm]
        for role, role_perms in ROLES.items():
            row.append("✅" if perm in role_perms else "❌")
        rows.append(row)

    print("\n📊 RBAC Permission Matrix")
    print(tabulate(rows, headers=headers, tablefmt="grid"))


if __name__ == "__main__":
    print("=" * 60)
    print("           RBAC ACCESS CONTROL SIMULATION")
    print("=" * 60)

    print_role_matrix()

    print("\n🔐 Access Control Checks:")
    print("-" * 60)

    # Test cases
    tests = [
        ("alice.johnson", "read_patient_records"),     # Should PASS
        ("alice.johnson", "prescribe_medication"),     # Should FAIL
        ("bob.smith",     "prescribe_medication"),     # Should PASS
        ("bob.smith",     "manage_users"),             # Should FAIL
        ("carol.davis",   "manage_users"),             # Should PASS
        ("carol.davis",   "read_patient_records"),     # Should FAIL
        ("dan.lee",       "view_audit_logs"),          # Should PASS
        ("dan.lee",       "update_patient_records"),   # Should FAIL
        ("unknown.user",  "read_patient_records"),     # Should FAIL
    ]

    for user, perm in tests:
        check_access(user, perm)
```

