### 2.2 ABAC with Python Simulation

Save this as `abac_sim.py`:

```python
#!/usr/bin/env python3
"""
ABAC Simulation — Healthcare Example
Evaluates access based on subject, resource, and environment attributes.
"""

from datetime import datetime


# ---------------------------------------------------------------------------
# Attribute Stores
# ---------------------------------------------------------------------------

SUBJECTS = {
    "alice.johnson": {
        "role":        "Nurse",
        "department":  "Oncology",
        "clearance":   2,
        "employment":  "full-time"
    },
    "bob.smith": {
        "role":        "Physician",
        "department":  "Oncology",
        "clearance":   3,
        "employment":  "full-time"
    },
    "carol.davis": {
        "role":        "ITAdmin",
        "department":  "IT",
        "clearance":   2,
        "employment":  "full-time"
    },
    "extern.vendor": {
        "role":        "Vendor",
        "department":  "External",
        "clearance":   1,
        "employment":  "contractor"
    }
}

RESOURCES = {
    "record:PT001": {
        "type":        "PatientRecord",
        "department":  "Oncology",
        "sensitivity": "HIGH"
    },
    "record:PT002": {
        "type":        "PatientRecord",
        "department":  "Cardiology",
        "sensitivity": "HIGH"
    },
    "report:AUD01": {
        "type":        "AuditReport",
        "department":  "Compliance",
        "sensitivity": "MEDIUM"
    },
    "system:HVAC": {
        "type":        "FacilitySystem",
        "department":  "Facilities",
        "sensitivity": "LOW"
    }
}


# ---------------------------------------------------------------------------
# Policy Engine
# ---------------------------------------------------------------------------

def get_environment() -> dict:
    """Simulate environment attributes."""
    now = datetime.now()
    return {
        "hour":       now.hour,
        "ip_internal": True,   # Simulate internal network
        "day_of_week": now.weekday()  # 0=Mon, 6=Sun
    }


def evaluate_policy(subject: dict, resource: dict, action: str, env: dict) -> tuple[bool, str]:
    """
    Policy Decision Point (PDP).
    Returns (permit: bool, reason: str)
    """

    # --- Policy 1: Patient Records ---
    # Nurses can read patient records in their own department during business hours
    if resource["type"] == "PatientRecord" and action == "read":
        if subject["role"] not in ("Nurse", "Physician"):
            return False, "Role not authorized for patient records"
        if subject["department"] != resource["department"]:
            return False, f"Department mismatch: {subject['department']} ≠ {resource['department']}"
        if not (6 <= env["hour"] <= 22):
            return False, "Access outside allowed hours (06:00–22:00)"
        if not env["ip_internal"]:
            return False, "Must be on internal network"
        return True, "All conditions met"

    # --- Policy 2: Patient Records — Write ---
    if resource["type"] == "PatientRecord" and action == "write":
        if subject["role"] != "Physician":
            return False, "Only Physicians can write patient records"
        if subject["clearance"] < 3:
            return False, f"Insufficient clearance level: {subject['clearance']} < 3"
        if subject["department"] != resource["department"]:
            return False, f"Department mismatch"
        return True, "Physician with sufficient clearance in correct department"

    # --- Policy 3: Audit Reports ---
    if resource["type"] == "AuditReport" and action == "read":
        if subject["role"] not in ("ITAdmin", "Auditor"):
            return False, "Only ITAdmin or Auditor roles can read audit reports"
        if subject["clearance"] < 2:
            return False, "Insufficient clearance for audit reports"
        return True, "Authorized role with sufficient clearance"

    # --- Policy 4: Deny contractors access to sensitive resources ---
    if subject["employment"] == "contractor" and resource["sensitivity"] in ("HIGH", "MEDIUM"):
        return False, "Contractors not permitted on sensitive resources"

    return False, "No matching policy — default DENY"


def check_access(username: str, resource_id: str, action: str) -> bool:
    """Full ABAC access check: gather attributes → evaluate policy → enforce."""
    subject = SUBJECTS.get(username)
    resource = RESOURCES.get(resource_id)
    env = get_environment()

    print(f"\n  Request: {username} → [{action}] {resource_id}")

    if not subject:
        print(f"  ❌ DENIED — Unknown subject '{username}'")
        return False
    if not resource:
        print(f"  ❌ DENIED — Unknown resource '{resource_id}'")
        return False

    permit, reason = evaluate_policy(subject, resource, action, env)

    if permit:
        print(f"  ✅ PERMIT — {reason}")
    else:
        print(f"  ❌ DENY   — {reason}")

    return permit


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    print("=" * 65)
    print("           ABAC ACCESS CONTROL SIMULATION")
    print("=" * 65)

    print(f"\n🕐 Environment: Hour={datetime.now().hour}, Internal Network=True")
    print("\n🔐 Policy Evaluations:")
    print("-" * 65)

    scenarios = [
        # (user,            resource,        action,  description)
        ("alice.johnson",  "record:PT001",  "read",  "Nurse reads own-dept patient record"),
        ("alice.johnson",  "record:PT002",  "read",  "Nurse reads OTHER-dept patient record"),
        ("alice.johnson",  "record:PT001",  "write", "Nurse tries to WRITE patient record"),
        ("bob.smith",      "record:PT001",  "read",  "Physician reads own-dept record"),
        ("bob.smith",      "record:PT001",  "write", "Physician writes own-dept record"),
        ("bob.smith",      "record:PT002",  "write", "Physician writes OTHER-dept record"),
        ("carol.davis",    "report:AUD01",  "read",  "ITAdmin reads audit report"),
        ("carol.davis",    "record:PT001",  "read",  "ITAdmin reads patient record"),
        ("extern.vendor",  "system:HVAC",   "read",  "Contractor reads LOW sensitivity system"),
        ("extern.vendor",  "record:PT001",  "read",  "Contractor reads HIGH sensitivity record"),
    ]

    for user, resource, action, desc in scenarios:
        print(f"\n  📌 {desc}")
        check_access(user, resource, action)
```

